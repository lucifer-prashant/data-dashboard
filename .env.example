# ── Personal Data Dashboard ── Environment Configuration
# Copy this file to .env.local and fill in your values.
# See README.md for detailed setup instructions.

NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=generate-a-long-random-secret-with-openssl-rand-base64-32

# Demo mode: set to "true" to show sample data without API credentials.
# Useful for portfolio preview or when you don't have real accounts connected.
DEMO_MODE=false

# ── OAuth Provider Credentials ──
# Leave empty to disable that provider. At least one is required for login.

# GitHub OAuth — https://github.com/settings/developers
GITHUB_ID=
GITHUB_SECRET=

# Google OAuth — https://console.cloud.google.com/
# Required scopes: Google Fit (fitness.activity.read) and Gmail (gmail.readonly)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Spotify — https://developer.spotify.com/dashboard
# Required scopes: user-read-currently-playing, user-read-recently-played, user-top-read
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
